    // =========================
    // 2. 更新 familyGroups
    // =========================
  // 如果自己離開後，群組已經沒有任何成員，就直接刪除群組
if (memberEmails.length === 0) {
  await db.collection('familyGroups').delete(currentGroup.id);
} else {
  await db.collection('familyGroups').update(currentGroup.id, {
    groupName: currentGroup.groupName || '',
